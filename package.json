{
  "name": "@olwiba/docs",
  "version": "0.0.2",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "olwibaDOCS - Fumadocs abstraction for TanStack Start documentation sites",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./styles": "./src/styles/docs.css",
    "./source": {
      "import": "./dist/lib/source.js"
    },
    "./mdx": {
      "import": "./dist/lib/mdx-components.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "web:build": "fumadocs-mdx && vite build",
    "web:dev": "fumadocs-mdx && vite dev",
    "start": "node dist/server/server.js",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "sync": "bun run scripts/sync-from-cn.ts",
    "sync:build": "bun run sync && bun run build",
    "prepublishOnly": "bun run build",
    "release": "npm publish --registry https://npm.olwiba.com/"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.4.7",
    "fumadocs-ui": "^16.4.7",
    "lucide-react": "^0.562.0",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "@olwiba/cn": ">=0.0.1",
    "@tanstack/react-router": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@olwiba/cn": "^0.0.2",
    "react-resizable-panels": "^4.4.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.151.6",
    "@tanstack/react-router-devtools": "^1.151.6",
    "@tanstack/react-start": "^1.153.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "fumadocs-mdx": "^14.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.0",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Olwiba/olwibaDOCS"
  },
  "author": "Olwiba",
  "license": "MIT"
}
