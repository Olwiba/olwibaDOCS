{
  "name": "@olwiba/docs",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "olwibaDOCS - Fumadocs abstraction for TanStack Start documentation sites",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles/docs.css",
    "./source": {
      "import": "./dist/lib/source.js",
      "types": "./dist/lib/source.d.ts"
    },
    "./mdx": {
      "import": "./dist/lib/mdx-components.js",
      "types": "./dist/lib/mdx-components.d.ts"
    },
    "./server": {
      "import": "./dist/lib/server.js",
      "types": "./dist/lib/server.d.ts"
    },
    "./themes": {
      "import": "./dist/lib/themes.js",
      "types": "./dist/lib/themes.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "web:build": "fumadocs-mdx && vite build",
    "web:dev": "fumadocs-mdx && vite dev",
    "start": "bun run server.ts",
    "tsc": "tsc",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "sync": "bun run scripts/sync-from-cn.ts",
    "sync:build": "bun run sync && bun run build",
    "prepublishOnly": "bun run build",
    "release": "npm publish"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.4.7",
    "fumadocs-ui": "^16.4.7",
    "hono": "^4.7.0",
    "lucide-react": "^0.562.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "@olwiba/cn": ">=0.1.2",
    "@tanstack/react-router": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@olwiba/cn": "^0.1.2",
    "react-resizable-panels": "^4.4.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-router": "^1.151.6",
    "@tanstack/react-router-devtools": "^1.151.6",
    "@tanstack/react-start": "^1.153.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "fumadocs-mdx": "^14.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.0",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Olwiba/olwibaDOCS"
  },
  "author": "Olwiba",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "types": "./dist/index.d.ts"
}
