PACKAGES_TOKEN=

# Feedback widget (optional). Unset or "none" hides the widget entirely.
# EMAIL_PROVIDER: none | preview | resend | plunk
EMAIL_PROVIDER=none
EMAIL_FROM="Docs Feedback <noreply@yourdomain.com>"
# Where feedback lands. EMAIL_ADMIN_TO falls back to EMAIL_REPLY_TO.
EMAIL_ADMIN_TO=
EMAIL_REPLY_TO=
# Provider credentials - only the active provider's key is needed.
RESEND_API_KEY=
PLUNK_API_KEY=
# Optional override for self-hosted Plunk.
PLUNK_API_URL=
